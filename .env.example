# ===================================
# VARIABLES DE ENTORNO - EJEMPLO
# ===================================
# Copia este archivo a .env y configura tus valores reales
# IMPORTANTE: Nunca subas el archivo .env a git

# ===================================
# BASE DE DATOS SQL SERVER
# ===================================
DB_SERVER=tu-servidor.database.windows.net
DB_DATABASE=Cobranza
DB_USER=tu-usuario
DB_PASSWORD=tu-password-segura

# ===================================
# AUTENTICACIÓN
# ===================================
JWT_SECRET=tu-secreto-jwt-super-seguro-cambia-esto

# ===================================
# API (Opcional)
# ===================================
# VITE_API_URL=https://tu-dominio.netlify.app

# ===================================
# reCAPTCHA (recomendado solo en producción)
# ===================================
# Backend (API): valida tokens cuando está en true
RECAPTCHA_ENABLED=false

# Frontend (Svelte): carga script y solicita token cuando está en true
VITE_RECAPTCHA_ENABLED=false
VITE_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
